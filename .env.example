APP_NAME=CarwashESP
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-app.laravel.cloud

# --- Logging ---
# En Laravel Cloud usar 'stderr' para que la plataforma capture los logs
LOG_CHANNEL=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Base de datos ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=carwash
DB_USERNAME=root
DB_PASSWORD=

# --- Drivers de infraestructura ---
# Laravel Cloud provee Redis — usar para cache, sesiones y colas
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# En cloud siempre HTTPS — mantener en true
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=true

# --- Redis (provisto por Laravel Cloud) ---
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Storage S3 / Cloudflare R2 ---
# El filesystem local es efímero en cloud — usar S3 o R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Broadcast ---
BROADCAST_DRIVER=log

# ================================================================
# SOLO PARA DESARROLLO LOCAL — sobreescribir estas vars en local:
# ================================================================
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://localhost
# LOG_CHANNEL=stack
# LOG_LEVEL=debug
# CACHE_DRIVER=file
# QUEUE_CONNECTION=sync
# SESSION_DRIVER=file
# SESSION_SECURE_COOKIE=false
# SESSION_ENCRYPT=false
# FILESYSTEM_DISK=local
# MAIL_HOST=mailhog
# MAIL_PORT=1025
